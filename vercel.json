{
  "version": 2,
  "name": "abc-computer-training-centre",
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/courses", "dest": "/courses.html" },
    { "src": "/gallery", "dest": "/gallery.html" },
    { "src": "/placements", "dest": "/placements.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/admission", "dest": "/admission.html" },
    { "src": "/payment", "dest": "/payment.html" },
    { "src": "/slip", "dest": "/slip.html" },
    { "src": "/faculty", "dest": "/faculty.html" },
    { "handle": "filesystem" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
